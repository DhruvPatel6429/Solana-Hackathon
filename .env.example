############################################
# Frontend
############################################

# Public: yes
# What: Browser network label (used in UI explorer links)
# Source: manual ("devnet" for this repo)
# Format: devnet | mainnet-beta
# Example: devnet
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Public: yes
# What: Browser Solana RPC (fallback is used if missing)
# Source: Helius/QuickNode/Solana public RPC
# Format: URL
# Example: https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Public: yes
# What: Supabase project URL for browser auth client
# Source: Supabase Dashboard > Project Settings > API > Project URL
# Format: URL
# Example: https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public: yes
# What: Supabase anon key for browser auth
# Source: Supabase Dashboard > Project Settings > API > anon public key
# Format: JWT-like key string
# Example: eyJhbGciOi...
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public: yes
# What: Enables judge-only demo endpoints/UI
# Source: manual
# Format: true|false
# Example: false
NEXT_PUBLIC_JUDGE_MODE=false

############################################
# Database
############################################

# Public: no (secret)
# What: Runtime DB URL used by Prisma client
# Source: Supabase DB connection string or self-hosted Postgres
# Format: postgresql://user:pass@host:port/db?sslmode=require
# Example: postgresql://postgres:password@db.xyz.supabase.co:6543/postgres?sslmode=require
DATABASE_URL=

# Public: no (secret)
# What: Direct DB URL for Prisma schema engine/migrations
# Source: Supabase direct connection (non-pooler) or direct Postgres endpoint
# Format: postgresql://user:pass@host:port/db?sslmode=require
# Example: postgresql://postgres:password@db.xyz.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=

############################################
# Supabase
############################################

# Public: no (secret)
# What: Supabase service role key (server-side privileged operations/scripts)
# Source: Supabase Dashboard > Project Settings > API > service_role
# Format: JWT-like key string
# Example: eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=

# Public: no (semi-secret but server only in this repo)
# What: Alternate Supabase URL name used by validation scripts
# Source: same as NEXT_PUBLIC_SUPABASE_URL
# Format: URL
# Example: https://xyzcompany.supabase.co
SUPABASE_URL=

############################################
# Solana
############################################

# Public: no (operational secret if paid endpoint)
# What: Server RPC endpoint used by payout/escrow services
# Source: Helius/QuickNode/Solana RPC
# Format: URL
# Example: https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Public: no
# What: USDC mint used by scripts (defaults to devnet USDC)
# Source: fixed for devnet unless custom mint
# Format: Solana public key
# Example: Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
DEVNET_USDC_MINT=

############################################
# Treasury
############################################

# Public: no (critical secret)
# What: Treasury signer private key (base58, 64-byte secret key)
# Source: export from Solana keypair file
# Format: base58 string decoding to 64 bytes
TREASURY_WALLET_SECRET_KEY=

# Public: no
# What: Treasury wallet public address
# Source: solana address -k <keypair.json>
# Format: Solana public key
TREASURY_WALLET_ADDRESS=

# Public: no
# What: CSV allowlist for treasury wallet guard checks
# Source: manual policy
# Format: comma-separated Solana public keys
# Example: ABC...,DEF...
TREASURY_WALLET_WHITELIST=

############################################
# Anchor / Escrow
############################################

# Public: no
# What: Escrow program ID used by payout engine
# Source: anchor deploy output
# Format: Solana public key
ESCROW_PROGRAM_ID=

# Public: no
# What: CSV allowlist for permitted escrow program IDs
# Source: manual policy
# Format: comma-separated Solana public keys
ALLOWED_ESCROW_PROGRAM_IDS=

# Public: no
# What: Optional recipient wallet blocklist
# Source: manual policy
# Format: comma-separated Solana public keys
RECIPIENT_WALLET_BLACKLIST=

############################################
# Dodo
############################################

# Public: no (secret)
# What: Dodo API key for checkout + usage APIs
# Source: Dodo developer dashboard
# Format: bearer token
DODO_API_KEY=

# Public: no
# What: Optional Dodo API base override
# Source: defaults to production API
# Format: URL
# Example: https://api.dodopayments.com
DODO_API_BASE_URL=https://test.dodopayments.com
DODO_BASE_URL=https://test.dodopayments.com
DODO_STARTER_PRODUCT_ID=
DODO_GROWTH_PRODUCT_ID=
DODO_ENTERPRISE_PRODUCT_ID=
DODO_STARTER_PRICE_ID=
DODO_GROWTH_PRICE_ID=
DODO_ENTERPRISE_PRICE_ID=

# Public: no (secret)
# What: HMAC secret for Dodo webhook verification
# Source: Dodo webhook configuration secret
# Format: plain string secret
DODO_WEBHOOK_SECRET=

############################################
# Helius
############################################

# Public: no (secret)
# What: Shared secret checked from Helius webhook header
# Source: Helius webhook auth secret
# Format: plain string secret
HELIUS_WEBHOOK_SECRET=

############################################
# Auth
############################################

# Public: no
# What: Origin used by CSRF check + production env validation
# Source: deployed app base URL
# Format: URL
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public: no
# What: Base URL used by certification scripts for endpoint checks
# Source: deployed app URL
# Format: URL
APP_BASE_URL=http://localhost:3000

# Public: no (secret)
# What: Admin bearer token for operational script checks
# Source: Supabase access token of admin user
# Format: JWT bearer token
ADMIN_BEARER_TOKEN=

############################################
# Webhooks
############################################

# Public: no
# What: Enables judge-mode demo webhook/data endpoints
# Source: manual
# Format: true|false
JUDGE_MODE=false

############################################
# Monitoring
############################################

# Public: no
# What: Sentry DSN (currently optional)
# Source: Sentry project settings
# Format: DSN URL
SENTRY_DSN=

############################################
# Email
############################################

# Public: no (secret)
# What: Resend API key for rejection emails
# Source: Resend dashboard
# Format: re_... key
RESEND_API_KEY=

############################################
# Compliance / Ops tuning
############################################

COMPLIANCE_LARGE_PAYOUT_ALERT_USDC=10000
COMPLIANCE_SUSPICIOUS_PAYOUT_ALERT_USDC=50000
COMPLIANCE_SINGLE_APPROVAL_LIMIT_USDC=25000
PG_DUMP_BINARY=pg_dump

############################################
# Testing / Devnet validation
############################################

TEST_RECIPIENT_WALLET=
TEST_TRANSFER_AMOUNT_USDC=0.01

TEST_CONTRACTOR_WALLET=
TEST_COMPANY_WALLET=
TEST_FEE_WALLET=

TEST_BATCH_WALLET_1=
TEST_BATCH_WALLET_2=
TEST_BATCH_WALLET_3=
TEST_BATCH_WALLET_4=
TEST_BATCH_WALLET_5=
BATCH_AMOUNT_USDC=0.02

LIVE_PAYROLL_AMOUNT_USDC=0.05
SPLIT_VALIDATION_AMOUNT_USDC=0.10
ANCHOR_VALIDATE_AMOUNT_USDC=0.01
HELIUS_VALIDATION_TRANSFER_USDC=0.01

RUN_REAL_DEMO_PAYOUT=0
MOCK_SOLANA_TX_SIGNATURE=

# E2E (used by tests/e2e/devnet-payroll-flow.test.ts)
DEVNET_E2E_DATABASE_URL=
E2E_CONTRACTOR_WALLET=
E2E_SECOND_CONTRACTOR_WALLET=
E2E_FEE_WALLET=
E2E_ESCROW_AMOUNT_USDC=0.10
E2E_SPLIT_AMOUNT_USDC=0.10
E2E_BATCH_AMOUNT_USDC=0.05
E2E_HELIUS_TOPUP_SIGNATURE=

# Load testing
LOADTEST_INVOICES=1000
LOADTEST_PAYOUTS=500
LOADTEST_BATCHES=100
LOADTEST_WEBHOOK_EVENTS=200
LOADTEST_DASHBOARD_REQUESTS=100
