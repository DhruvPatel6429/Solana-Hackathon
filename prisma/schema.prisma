generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Payout {
  id               String    @id @default(cuid())
  invoiceId        String
  contractorWallet String
  amountUsdc       Float
  escrowPda        String?
  txSignature      String?
  status           String
  createdAt        DateTime  @default(now())
  executedAt       DateTime?

  @@unique([invoiceId])
  @@index([escrowPda])
  @@index([status])
  @@index([contractorWallet])
}
