generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PayoutPreference {
  USDC
  FIAT
}

enum InvoiceStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum OrganizationMemberRole {
  OWNER
  ADMIN
  FINANCE
  COMPLIANCE
  VIEWER
}

enum ComplianceSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplianceStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Organization {
  id                String                     @id @default(cuid())
  name              String
  slug              String                     @unique
  status            String                     @default("ACTIVE")
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  companies         Company[]
  members           OrganizationMember[]
  apiKeys           ApiKey[]
  partnerIntegrations PartnerIntegration[]
  complianceAlerts  ComplianceAlert[]
  governancePolicies GovernancePolicy[]
  recoverySnapshots DisasterRecoverySnapshot[]
}

model Company {
  id                   String       @id @default(cuid())
  organizationId       String?
  name                 String
  planTier             String?
  dodoCustomerId       String?
  dodoSubscriptionId   String?
  treasuryWalletAddress String?
  feeWalletAddress     String?
  treasuryBalanceUsdc  Decimal      @default(0)
  treasuryBalanceUpdatedAt DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  users                CompanyUser[]
  contractors          Contractor[]
  invoices             Invoice[]
  payouts              Payout[]
  usageEvents          UsageEvent[]
  auditLogs            AuditLog[]
  billingEvents        BillingEvent[]
  treasuryTransactions TreasuryTransaction[]
  apiKeys              ApiKey[]
  partnerIntegrations  PartnerIntegration[]
  partnerWebhookSubscriptions PartnerWebhookSubscription[]
  complianceAlerts     ComplianceAlert[]
  governancePolicies   GovernancePolicy[]
  recoverySnapshots    DisasterRecoverySnapshot[]

  @@index([organizationId])
}

model CompanyUser {
  id        String   @id @default(cuid())
  organizationId String?
  companyId String
  userId    String   @unique
  role      String   @default("admin")
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([companyId])
}

model Contractor {
  id               String    @id @default(cuid())
  organizationId   String?
  companyId        String
  name             String
  email            String    @default("")
  country          String?
  taxId            String?
  payoutPreference String    @default("USDC")
  walletAddress    String?
  preferredFiatCurrency String?
  kycStatus        String    @default("PENDING")
  status           String    @default("Active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices         Invoice[]
  payouts          Payout[]

  @@index([organizationId])
  @@index([companyId])
  @@index([kycStatus])
}

model Invoice {
  id           String    @id @default(cuid())
  organizationId String?
  companyId    String
  contractorId String
  amountUsdc   Decimal
  status       String    @default("PENDING")
  invoiceHash  String?
  description  String?
  notes        String?
  rejectionReason String?
  submittedAt  DateTime  @default(now())
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  payouts      Payout[]

  @@index([organizationId])
  @@index([companyId])
  @@index([contractorId])
  @@index([status])
}

model Payout {
  id               String    @id @default(cuid())
  organizationId   String?
  companyId        String?
  contractorId     String?
  invoiceId        String
  contractorWallet String
  amountUsdc       Decimal
  currency         String    @default("USDC")
  escrowPda        String?
  txSignature      String?
  status           String
  createdAt        DateTime  @default(now())
  executedAt       DateTime?
  company          Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contractor       Contractor? @relation(fields: [contractorId], references: [id], onDelete: SetNull)
  invoice          Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId])
  @@index([organizationId])
  @@index([companyId])
  @@index([contractorId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([escrowPda])
  @@index([status])
  @@index([contractorWallet])
}

model UsageEvent {
  id         String   @id @default(cuid())
  organizationId String?
  companyId  String
  eventType  String
  dodoEventId String?
  reportedAt DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([companyId])
  @@index([eventType])
}

model AuditLog {
  id          String   @id @default(cuid())
  organizationId String?
  companyId   String
  action      String
  actorUserId String?
  metadata    Json?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([companyId])
  @@index([createdAt])
  @@index([action])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  organizationId String?
  companyId   String?
  provider    String
  externalId  String?
  eventType   String
  signature   String?
  payload     Json
  processed   Boolean  @default(false)
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([provider, externalId])
  @@index([organizationId])
  @@index([companyId])
  @@index([provider])
  @@index([eventType])
  @@index([processed])
  @@index([processedAt])
}

model BillingEvent {
  id            String   @id @default(cuid())
  organizationId String?
  companyId     String?
  dodoPaymentId String   @unique
  customerEmail String?
  amountUsd     Decimal
  currency      String
  status        String
  rawPayload    Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model TreasuryTransaction {
  id            String   @id @default(cuid())
  organizationId String?
  companyId     String?
  signature     String   @unique
  walletAddress String
  amountUsdc    Decimal
  direction     String
  source        String?
  destination   String?
  slot          BigInt?
  createdAt     DateTime @default(now())
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([companyId])
  @@index([walletAddress])
  @@index([direction])
  @@index([createdAt])
}

model FailedJob {
  id             String    @id @default(cuid())
  organizationId String?
  companyId      String?
  jobType        String
  entityType     String?
  entityId       String?
  status         String    @default("PENDING_RETRY")
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  nextRetryAt    DateTime?
  lastError      String?
  metadata       Json?
  correlationId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  resolvedAt     DateTime?

  @@index([organizationId])
  @@index([companyId])
  @@index([jobType])
  @@index([status])
  @@index([nextRetryAt])
  @@index([entityType, entityId])
}

model DeadLetterWebhook {
  id             String    @id @default(cuid())
  organizationId String?
  companyId      String?
  provider       String
  externalId     String?
  eventType      String?
  signature      String?
  nonce          String?
  status         String    @default("PENDING_REPLAY")
  attempts       Int       @default(0)
  nextRetryAt    DateTime?
  lastError      String?
  payload        Json
  correlationId  String?
  receivedAt     DateTime  @default(now())
  processedAt    DateTime?

  @@unique([provider, externalId])
  @@index([organizationId])
  @@index([companyId])
  @@index([provider])
  @@index([status])
  @@index([nextRetryAt])
  @@index([receivedAt])
}

model ReconciliationAudit {
  id             String   @id @default(cuid())
  organizationId String?
  companyId      String?
  scope          String
  entityType     String?
  entityId       String?
  severity       String   @default("INFO")
  status         String   @default("OPEN")
  expectedValue  Decimal?
  actualValue    Decimal?
  deltaValue     Decimal?
  txSignature    String?
  metadata       Json?
  correlationId  String?
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  @@index([organizationId])
  @@index([companyId])
  @@index([scope])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model OrganizationMember {
  id             String                  @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationMemberRole @default(ADMIN)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model ApiKey {
  id               String       @id @default(cuid())
  organizationId   String
  companyId        String?
  name             String
  keyPrefix        String
  keyHash          String       @unique
  scopes           Json
  status           ApiKeyStatus @default(ACTIVE)
  expiresAt        DateTime?
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  createdByUserId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([companyId])
}

model PartnerIntegration {
  id                    String       @id @default(cuid())
  organizationId        String
  companyId             String?
  partnerName           String
  partnerReference      String?
  embeddingEnabled      Boolean      @default(false)
  brandedConfiguration  Json?
  payoutApiEnabled      Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company               Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  webhookSubscriptions  PartnerWebhookSubscription[]

  @@index([organizationId])
  @@index([companyId])
}

model PartnerWebhookSubscription {
  id                   String             @id @default(cuid())
  organizationId       String
  companyId            String?
  partnerIntegrationId String
  targetUrl            String
  eventTypes           Json
  secretHash           String
  status               String             @default("ACTIVE")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  partnerIntegration   PartnerIntegration @relation(fields: [partnerIntegrationId], references: [id], onDelete: Cascade)
  company              Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([companyId])
  @@index([partnerIntegrationId])
}

model ComplianceAlert {
  id                  String             @id @default(cuid())
  organizationId      String
  companyId           String?
  scope               String
  severity            ComplianceSeverity @default(MEDIUM)
  status              ComplianceStatus   @default(OPEN)
  entityType          String?
  entityId            String?
  thresholdRule       String?
  amountUsdc          Decimal?
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  resolvedAt          DateTime?
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company             Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([companyId])
  @@index([severity])
}

model GovernancePolicy {
  id               String       @id @default(cuid())
  organizationId   String
  companyId        String?
  policyType       String
  value            Json
  status           String       @default("ACTIVE")
  createdByUserId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([organizationId, policyType])
  @@index([companyId])
}

model DisasterRecoverySnapshot {
  id                String       @id @default(cuid())
  organizationId    String
  companyId         String?
  snapshotType      String
  reference         String?
  payload           Json
  createdAt         DateTime     @default(now())
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company           Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([organizationId, snapshotType])
  @@index([companyId])
}
