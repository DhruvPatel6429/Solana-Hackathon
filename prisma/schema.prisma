generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PayoutPreference {
  USDC
  FIAT
}

enum InvoiceStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Company {
  id                   String       @id @default(cuid())
  name                 String
  planTier             String?
  dodoCustomerId       String?
  dodoSubscriptionId   String?
  treasuryWalletAddress String?
  treasuryBalanceUsdc  Decimal      @default(0)
  treasuryBalanceUpdatedAt DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  users                CompanyUser[]
  contractors          Contractor[]
  invoices             Invoice[]
  payouts              Payout[]
  usageEvents          UsageEvent[]
  auditLogs            AuditLog[]
  billingEvents        BillingEvent[]
  treasuryTransactions TreasuryTransaction[]
}

model CompanyUser {
  id        String   @id @default(cuid())
  companyId String
  userId    String   @unique
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Contractor {
  id               String    @id @default(cuid())
  companyId        String
  name             String
  email            String    @default("")
  country          String?
  taxId            String?
  payoutPreference String    @default("USDC")
  walletAddress    String?
  preferredFiatCurrency String?
  kycStatus        String    @default("PENDING")
  status           String    @default("Active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices         Invoice[]
  payouts          Payout[]

  @@index([companyId])
  @@index([kycStatus])
}

model Invoice {
  id           String    @id @default(cuid())
  companyId    String
  contractorId String
  amountUsdc   Decimal
  status       String    @default("PENDING")
  invoiceHash  String?
  description  String?
  notes        String?
  rejectionReason String?
  submittedAt  DateTime  @default(now())
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  payouts      Payout[]

  @@index([companyId])
  @@index([contractorId])
  @@index([status])
}

model Payout {
  id               String    @id @default(cuid())
  companyId        String?
  contractorId     String?
  invoiceId        String
  contractorWallet String
  amountUsdc       Decimal
  currency         String    @default("USDC")
  escrowPda        String?
  txSignature      String?
  status           String
  createdAt        DateTime  @default(now())
  executedAt       DateTime?
  company          Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contractor       Contractor? @relation(fields: [contractorId], references: [id], onDelete: SetNull)
  invoice          Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId])
  @@index([companyId])
  @@index([contractorId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([escrowPda])
  @@index([status])
  @@index([contractorWallet])
}

model UsageEvent {
  id         String   @id @default(cuid())
  companyId  String
  eventType  String
  dodoEventId String?
  reportedAt DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([eventType])
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String
  action      String
  actorUserId String?
  metadata    Json?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([createdAt])
  @@index([action])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  externalId  String?
  eventType   String
  signature   String?
  payload     Json
  processed   Boolean  @default(false)
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([provider, externalId])
  @@index([provider])
  @@index([eventType])
  @@index([processed])
  @@index([processedAt])
}

model BillingEvent {
  id            String   @id @default(cuid())
  companyId     String?
  dodoPaymentId String   @unique
  customerEmail String?
  amountUsd     Decimal
  currency      String
  status        String
  rawPayload    Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model TreasuryTransaction {
  id            String   @id @default(cuid())
  companyId     String?
  signature     String   @unique
  walletAddress String
  amountUsdc    Decimal
  direction     String
  source        String?
  destination   String?
  slot          BigInt?
  createdAt     DateTime @default(now())
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([walletAddress])
  @@index([direction])
  @@index([createdAt])
}
