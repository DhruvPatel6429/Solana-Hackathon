# Dependencies
node_modules/

# Environment and local secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js build output and cache
.next/
out/

# TypeScript / tool caches
*.tsbuildinfo

# Test coverage and logs
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Rust / Cargo / Anchor / Solana generated build output
target/
programs/*/target/
**/debug/
**/release/
**/.fingerprint/
**/incremental/
**/deps/
**/build/
**/.rustc_info.json
**/CACHEDIR.TAG
**/.cargo-lock
**/.cargo-build-lock
**/.cargo-artifact-lock

# Cargo lockfile for the on-chain program is generated locally and not required
programs/*/Cargo.lock

# Keep runtime-required IDL committed in app source
!lib/solana/idl/
!lib/solana/idl/escrow.json

# Anchor-generated root target tree is ignored by default.
# If you intentionally want to share a demo keypair, remove this ignore and
# commit target/deploy/escrow-keypair.json explicitly.

# Generated validation/demo artifacts
artifacts/

# Prisma local/generated noise
prisma/*.db
prisma/*.db-journal

# Local binaries, wallets, temp folders, and scratch files
ngrok.exe
treasury-wallet.json
convert.js
disc.py
see.txt
~
~/
*.tmp
*.temp

# OS / editor junk
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
